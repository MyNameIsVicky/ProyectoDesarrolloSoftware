@model ProyectoDesarrolloSoftware.Models.Especialidad

@{
    ViewData["Title"] = "Nueva Especialidad";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="text-center mb-4">
                <h2 class="text-primary fw-bold display-5">Registrar Especialidad</h2>
                <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
                <hr class="w-25 mx-auto text-primary" />
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 rounded-2"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Nombre" class="form-label small fw-bold">Nombre de la Especialidad</label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Cardiología" />
                            <span asp-validation-for="Nombre" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="d-flex flex-column flex-md-row gap-2 mt-4">
                            <button type="submit" class="btn btn-outline-primary py-2 fw-bold flex-fill rounded-2">Registrar Especialidad</button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 fw-bold flex-fill rounded-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}