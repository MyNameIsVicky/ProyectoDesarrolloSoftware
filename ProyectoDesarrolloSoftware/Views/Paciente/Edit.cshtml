@model ProyectoDesarrolloSoftware.Models.ViewModels.UsuarioViewModel
@{
    ViewData["Title"] = "Editar Paciente";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="display-4">Modificar Registro</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3 text-start">
                        <label asp-for="NombreCompleto" class="form-label fw-bold">Nombre Completo</label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label asp-for="Cedula" class="form-label fw-bold">Cédula de Identidad</label>
                        <input asp-for="Cedula" class="form-control" />
                        <span asp-validation-for="Cedula" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label asp-for="UserName" class="form-label fw-bold">Nombre de Usuario</label>
                        <input asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label asp-for="Correo" class="form-label fw-bold">Correo Electrónico</label>
                        <input asp-for="Correo" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary w-100 py-2">Actualizar Cambios</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">Cancelar</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}