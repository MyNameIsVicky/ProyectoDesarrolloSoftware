@model IEnumerable<ProyectoDesarrolloSoftware.Models.ViewModels.UsuarioViewModel>

@{
    ViewData["Title"] = "Administración de Usuarios";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-4">Administración de Usuarios</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="mb-4 text-start">
        <a asp-action="Create" asp-controller="Usuario" class="btn btn-outline-primary px-4 shadow-sm">
            + Nuevo Usuario
        </a>
    </div>

    <div class="card shadow-sm border-0 p-4 mb-5">
        <div class="table-responsive">
            <table id="usuariosTable" class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Cédula</th>
                        <th>Perfil</th>
                        <th>Estado</th>
                        <th style="width: 230px;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr class="@(u.Bloqueado ? "table-danger" : "")">
                            <td><strong>@u.NombreCompleto</strong></td>
                            <td>@u.Correo</td>
                            <td>@u.Cedula</td>
                            <td><span class="badge bg-light text-dark border">@u.Perfil</span></td>
                            <td>
                                @if (u.Bloqueado){
                                    <span class="badge bg-danger">Bloqueado</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="Edit" asp-controller="Usuario" asp-route-id="@u.Id"
                                       class="btn btn-outline-primary btn-sm px-3">Editar</a>

                                    <form asp-action="ToggleBloqueo" asp-controller="Usuario"
                                          method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit"
                                                class="btn btn-sm px-3 @(u.Bloqueado ? "btn-outline-success" : "btn-outline-secondary")">
                                            @(u.Bloqueado ? "Desbloquear" : "Bloquear")
                                        </button>
                                    </form>

                                    <a asp-action="Delete" asp-controller="Usuario" asp-route-id="@u.Id"
                                       class="btn btn-outline-danger btn-sm px-3">Eliminar</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center mb-5">
        <a class="btn btn-outline-light px-4 shadow-sm" href="/Administracion/VistaAdministracion" role="button">
            Volver al Panel de Administración
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#usuariosTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            toastr.success('@(TempData["SuccessMessage"])');
        </script>
    }
}
