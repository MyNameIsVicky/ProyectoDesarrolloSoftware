@model ProyectoDesarrolloSoftware.Models.ViewModels.UsuarioViewModel
{

@{
    ViewData["Title"] = "Editar Usuario";
    bool esMedico = Model.Perfil == Perfil.Medico;
    bool esPaciente = Model.Perfil == Perfil.Paciente;
}

<div class="container my-5" style="padding-bottom: 60px;">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="text-center mb-4">
                <h2 class="text-primary fw-bold display-5">Editar Usuario</h2>
                <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
                <hr class="w-25 mx-auto text-primary" />
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4 p-md-5">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 rounded-2"></div>

                   <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Perfil" />
                        @if (esMedico)
                        {
                            <input type="hidden" asp-for="MedicoId" />
                        }

                        <h5 class="fw-bold text-muted mb-3">Datos de Cuenta</h5>

                        <div class="form-group mb-3">
                            <label asp-for="UserName" class="form-label small fw-bold">Nombre de usuario</label>
                            <input asp-for="UserName" class="form-control" placeholder="Ej: mvfallas" autocomplete="username" />
                            <div class="form-text">Con este nombre se inicia sesión.</div>
                            <span asp-validation-for="UserName" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Correo" class="form-label small fw-bold">Correo electrónico</label>
                            <input asp-for="Correo" class="form-control" placeholder="correo@ejemplo.com" />
                            <span asp-validation-for="Correo" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label small fw-bold">
                                Nueva contraseña <span class="text-muted fw-normal">(dejar vacío para no cambiarla)</span>
                            </label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="••••••••" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                        </div>

                        @* Datos personales solo para pacientes *@
                        @if (esPaciente)
                        {
                            <hr class="my-4 text-muted" />
                            <h5 class="fw-bold text-muted mb-3">Datos del Paciente</h5>

                            <div class="form-group mb-3">
                                <label asp-for="NombreCompleto" class="form-label small fw-bold">Nombre Completo</label>
                                <input asp-for="NombreCompleto" class="form-control" placeholder="Ej: Victoria Fallas" />
                                <span asp-validation-for="NombreCompleto" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Cedula" class="form-label small fw-bold">Cédula</label>
                                <input asp-for="Cedula" class="form-control" placeholder="Ej: 1-1234-5678" />
                                <span asp-validation-for="Cedula" class="text-danger small d-block mt-1"></span>
                            </div>
                        }

                        <div class="d-flex flex-column flex-md-row gap-2 mt-4">
                            <button type="submit" class="btn btn-outline-primary py-2 fw-bold flex-fill rounded-2">
                                Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 fw-bold flex-fill rounded-2">
                                Cancelar
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
