@model ProyectoDesarrolloSoftware.Models.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="display-4">Editar Usuario</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 rounded-2"></div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3 text-start">
                        <label asp-for="NombreCompleto" class="form-label fw-bold small">Nombre Completo</label>
                        <input asp-for="NombreCompleto" class="form-control" />
                        <span asp-validation-for="NombreCompleto" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label asp-for="Cedula" class="form-label fw-bold small">Cédula</label>
                        <input asp-for="Cedula" class="form-control" />
                        <span asp-validation-for="Cedula" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3 text-start">
                        <label asp-for="Correo" class="form-label fw-bold small">Correo Electrónico</label>
                        <input asp-for="Correo" type="email" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Perfil" class="form-label small fw-bold">Perfil</label>
                        <select asp-for="Perfil" class="form-select" id="perfilSelect">
                            <option value="Paciente">Paciente</option>
                            <option value="Medico">Médico</option>
                            <option value="Admin">Administrador</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-outline-primary py-2 fw-bold flex-fill rounded-2">Guardar Cambios</button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-2 fw-bold flex-fill rounded-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
