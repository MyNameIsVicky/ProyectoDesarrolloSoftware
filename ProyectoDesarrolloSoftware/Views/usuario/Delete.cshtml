@model ProyectoDesarrolloSoftware.Models.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="text-danger fw-bold display-5">¿Está seguro de eliminar este usuario?</h2>
        <p class="text-muted lead">Esta acción eliminará permanentemente al usuario y sus credenciales de acceso.</p>
        <hr class="w-25 mx-auto text-danger" />
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-3 p-4">
                <h4 class="fs-4 text-secondary fw-bold mb-3 text-center">Detalles del Usuario</h4>

                <dl class="row mb-4">
                    <dt class="col-sm-4 fw-bold">Nombre:</dt>
                    <dd class="col-sm-8">@Model.NombreCompleto</dd>

                    <dt class="col-sm-4 fw-bold">Correo:</dt>
                    <dd class="col-sm-8">@Model.Correo</dd>

                    <dt class="col-sm-4 fw-bold">Cédula:</dt>
                    <dd class="col-sm-8">@Model.Cedula</dd>

                    <dt class="col-sm-4 fw-bold">Perfil:</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-light text-dark border">@Model.Perfil</span>
                    </dd>

                    <dt class="col-sm-4 fw-bold">Estado:</dt>
                    <dd class="col-sm-8">
                        @if (Model.Bloqueado)
                        {
                            <span class="badge bg-danger">Bloqueado</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex flex-column flex-md-row gap-2">
                        <button type="submit" class="btn btn-outline-danger py-2 fw-bold flex-fill rounded-2">Sí, Eliminar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-2 fw-bold flex-fill rounded-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="text-center mt-4 mb-5">
        <a class="btn btn-outline-light px-4 shadow-sm" asp-action="Index" role="button">
            Volver al listado
        </a>
    </div>
</div>
