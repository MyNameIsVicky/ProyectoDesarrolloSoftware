@model ProyectoDesarrolloSoftware.Models.ModuloMedicina.Medicamento

@{
    ViewData["Title"] = "Editar Medicamento";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="display-4 fw-bold text-primary">Modificar Medicamento</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto text-primary" />
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0 rounded-3">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 rounded-2"></div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-4">
                        <label asp-for="NombreMedicamento" class="form-label small fw-bold">Nombre del Medicamento</label>
                        <input asp-for="NombreMedicamento" class="form-control" />
                        <span asp-validation-for="NombreMedicamento" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-2">Actualizar Cambios</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2 fw-bold rounded-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
