@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">Acceso al Sistema</h2>
                        <p class="text-muted small">Ingrese sus credenciales para continuar</p>
                    </div>
                    <form asp-controller="Cuenta" asp-action="Login" method="post">
                        <div class="form-group mb-3 text-start">
                            <label class="form-label fw-bold">Nombre de Usuario</label>
                            <input type="text" name="username" class="form-control" placeholder="Ingrese su nombre de usuario" required />
                        </div>
                        <div class="form-group mb-4 text-start">
                            <label class="form-label fw-bold">Contraseña</label>
                            <input type="password" name="password" class="form-control" placeholder="Ingrese su contraseña" required />
                        </div>
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2 small text-center" role="alert">
                                @ViewBag.Error
                            </div>
                        }
                        <button type="submit" class="btn btn-outline-primary w-100 py-2 mt-2 fw-bold">Ingresar</button>
                    </form>

                    <hr class="my-4" />

                    <p class="text-center text-muted small mb-0">
                        ¿No tiene cuenta? <a asp-controller="Cuenta" asp-action="Registrar">Registrarse como paciente</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
