@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-4">Módulo de Administración</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="row justify-content-center g-4">

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Especialidades</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver especialidades.</p>
                    </div>
                    <a href="/Especialidad/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Especialidades
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Médicos Tratantes</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver el registro de doctores.</p>
                    </div>
                    <a href="/Medico/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Médicos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Usuarios</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver usuarios.</p>
                    </div>
                    <a href="/Usuarios/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Usuarios
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="text-center mt-5">
        <a class="btn btn-outline-danger px-4 shadow-sm" href="/Home/Index" role="button">
            Volver
        </a>
    </div>
</div>