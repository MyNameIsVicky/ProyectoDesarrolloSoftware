
@{
    ViewData["Title"] = "Panel de medicos";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-4">Módulo de medicina</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="row justify-content-center g-4">

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Pacientes</h3>
                        <p class="text-muted small">Ver listado de pacientes, buscar por nombre o cédula e ingresar al expediente.</p>
                    </div>
                    <a href="/Paciente/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Pacientes
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Padecimientos</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver padecimientos médicos.</p>
                    </div>
                    <a href="/Padecimiento/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Padecimientos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Tratamientos</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver tratamientos asignados.</p>
                    </div>
                    <a href="/Tratamiento/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Tratamientos
                    </a>
                </div>
            </div>
        </div>

        
        <div class="col-md-4">
            <div class="card h-100 text-center p-4 shadow-sm border-0">
                <div class="card-body d-flex flex-column justify-content-between">
                    <div class="mb-4">
                        <h3 class="h4 card-title font-weight-bold">Medicamentos</h3>
                        <p class="text-muted small">Registrar, administrar, eliminar y ver catálogo de medicamentos.</p>
                    </div>
                    <a href="/Medicamento/Index" class="btn btn-outline-primary w-100 py-2">
                        Administrar Medicamentos
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="text-center mt-5">
        <a class="btn btn-danger px-4 shadow-sm" href="/Home/Index" role="button">
            Volver
        </a>
    </div>
</div>