@model IEnumerable<ProyectoDesarrolloSoftware.Models.Medico>

@{
    ViewData["Title"] = "Gestión de Médicos";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-4">Médicos Tratantes</h2>
        <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
        <hr class="w-25 mx-auto" />
    </div>

    <div class="mb-4 text-start">
        <a asp-action="Create" asp-controller="Medico" class="btn btn-outline-primary px-4 shadow-sm">
            + Registrar Nuevo Médico
        </a>
    </div>

    <div class="card shadow-sm border-0 p-4 mb-5">
        <div class="table-responsive">
            <table id="medicosTable" class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 8%;">ID</th>
                        <th style="width: 10%;">Foto</th>
                        <th>Nombre Médico</th>
                        <th>N° Colegiado</th>
                        <th>Cédula</th>
                        <th>Especialidades</th>
                        <th style="width: 20%;" class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var medico in Model)
                    {
                        <tr>
                            <td><strong>@medico.Id</strong></td>
                            <td>
                                <img src="@medico.FotoUrl" alt="Foto" class="rounded-circle shadow-sm" style="width:100px; height:100px; object-fit:cover;" />
                            </td>
                            <td class="font-weight-bold">@medico.NombreCompleto</td>
                            <td><span class="badge bg-light text-dark border">@medico.NumeroColegiado</span></td>
                            <td>@medico.CedulaFisica</td>
                            <td>
                                @if (medico.MedicosEspecialidades != null && medico.MedicosEspecialidades.Any())
                                {
                                    foreach (var me in medico.MedicosEspecialidades)
                                    {
                                        <span class="badge bg-light text-dark border">@me.Especialidad.Nombre</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Ninguna asignada</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="Edit" asp-controller="Medico" asp-route-id="@medico.Id" class="btn btn-outline-primary btn-sm px-3">
                                        Editar
                                    </a>
                                    <a asp-action="Delete" asp-controller="Medico" asp-route-id="@medico.Id" class="btn btn-outline-danger btn-sm px-3">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-center mb-5">
        <a class="btn btn-outline-light px-4 shadow-sm" href="/Home/Index" role="button">
            Volver al Menú Principal
        </a>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function(){
            $('#medicosTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' // Muestra el diccionario en español de manera limpia
                }
            });
        });
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            toastr.success('@(TempData["SuccessMessage"])');
        </script>
    }

    <script>
        async function confirmDelete(id) {
            const result = await Swal.fire({
                title: "¿Está seguro?",
                text: "¡No podrá revertir el registro de este médico!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Sí, eliminar médico",
                cancelButtonText: "Cancelar"
            });

            if (!result.isConfirmed) return;

            const httpResponse = await fetch(`/api/MedicoApi/${id}`, {
                method: "DELETE"
            });

            if (httpResponse.ok) {
                toastr.success("Médico eliminado correctamente");
                setTimeout(() => { location.reload(); }, 1000);
            } else {
                toastr.error("Hubo un error al intentar eliminar el registro");
            }
        }
    </script>
}