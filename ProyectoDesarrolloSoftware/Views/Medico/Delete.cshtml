@model ProyectoDesarrolloSoftware.Models.Medico

@{
    ViewData["Title"] = "Eliminar Médico";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="text-danger fw-bold display-5">¿Está seguro de eliminar este registro?</h2>
        <p class="text-muted lead">Esta acción eliminará permanentemente al médico y sus credenciales de acceso.</p>
        <hr class="w-25 mx-auto text-danger" />
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3 p-4">
                <h4 class="fs-4 text-secondary fw-bold mb-3 text-center">Detalles del Médico</h4>

                <div class="text-center mb-4">
                    <img src="@Model.FotoUrl" alt="Foto Médico" class="rounded-circle border" style="width: 100px; height: 100px; object-fit: cover;" />
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4 fw-bold">Nombre:</dt>
                    <dd class="col-sm-8">@Model.NombreCompleto</dd>

                    <dt class="col-sm-4 fw-bold">Cédula:</dt>
                    <dd class="col-sm-8">@Model.CedulaFisica</dd>

                    <dt class="col-sm-4 fw-bold">Nº Colegiado:</dt>
                    <dd class="col-sm-8">@Model.NumeroColegiado</dd>
                </dl>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex flex-column flex-md-row gap-2">
                        
                        <button type="submit" class="btn btn-outline-danger py-2 fw-bold flex-fill rounded-2">Sí, Eliminar</button>
                        <a asp-action="Index" class="btn btn-outline-info py-2 fw-bold flex-fill rounded-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>