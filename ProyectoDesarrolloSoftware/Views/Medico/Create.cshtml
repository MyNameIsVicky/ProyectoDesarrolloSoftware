@model ProyectoDesarrolloSoftware.Models.ViewModel.MedicoVM

@{
    ViewData["Title"] = "Registrar Médico";
}

<div class="container my-5" style="padding-bottom: 60px;">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="text-center mb-4">
                <h2 class="text-primary fw-bold display-5">Registrar Médico</h2>
                <p class="text-muted lead">Centro Médico Carlos Monge Alfaro</p>
                <hr class="w-25 mx-auto text-primary" />
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4 rounded-2"></div>

                        <div class="row g-4">
                            <div class="col-md-6 border-end">
                                <h4 class="fs-5 text-secondary fw-bold mb-3">1. Credenciales de Acceso</h4>

                                <div class="form-group mb-3">
                                    <label asp-for="Username" class="form-label small fw-bold">Nombre de Usuario</label>
                                    <input asp-for="Username" class="form-control" placeholder="Ej: jpmendez" />
                                    <span asp-validation-for="Username" class="text-danger small d-block mt-1"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Email" class="form-label small fw-bold">Correo Electrónico</label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="medico@hospital.com" />
                                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Password" class="form-label small fw-bold">Contraseña Temporal</label>
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" />
                                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h4 class="fs-5 text-secondary fw-bold mb-3">2. Datos Profesionales</h4>

                                <div class="form-group mb-3">
                                    <label asp-for="Medico.NombreCompleto" class="form-label small fw-bold">Nombre Completo</label>
                                    <input asp-for="Medico.NombreCompleto" class="form-control" placeholder="Ej: Dr. Carlos Monge" />
                                    <span asp-validation-for="Medico.NombreCompleto" class="text-danger small d-block mt-1"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Medico.CedulaFisica" class="form-label small fw-bold">Cédula de Identidad</label>
                                    <input asp-for="Medico.CedulaFisica" class="form-control" placeholder="Ej: 1-1111-1111" />
                                    <span asp-validation-for="Medico.CedulaFisica" class="text-danger small d-block mt-1"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Medico.NumeroColegiado" class="form-label small fw-bold">Número de Colegiado</label>
                                    <input asp-for="Medico.NumeroColegiado" class="form-control" placeholder="Ej: MED-001" />
                                    <span asp-validation-for="Medico.NumeroColegiado" class="text-danger small d-block mt-1"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Medico.FotoUrl" class="form-label small fw-bold">URL de Fotografía (Opcional)</label>
                                    <input asp-for="Medico.FotoUrl" class="form-control" placeholder="https://ejemplo.com/foto.jpg" />
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 text-muted" />

                        <div class="form-group mb-4 bg-light p-3 rounded-3 border">
                            <label class="form-label fw-bold text-secondary mb-1">3. Especialidades Médicas</label>
                            <p class="text-muted small mb-2">Mantenga presionado Ctrl (o Cmd en Mac) para seleccionar múltiples opciones:</p>

                            <select asp-for="EspecialidadesIds" asp-items="@ViewBag.Especialidades" class="form-select" multiple="multiple" style="height: 115px;"></select>
                            <span asp-validation-for="EspecialidadesIds" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="d-flex flex-column flex-md-row gap-2 mt-4">
                            <button type="submit" class="btn btn-outline-primary py-2 fw-bold flex-fill rounded-2">Registrar Médico</button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2 fw-bold flex-fill rounded-2">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}